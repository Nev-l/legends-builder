class classes.data.SupportCenterFormData
{
   function SupportCenterFormData()
   {
   }
   static function setupDisplayText(_menuArray)
   {
      var _loc2_ = "The official 1320 Legends policy on compromised accounts is as follows: ";
      _loc2_ += "<font color=\'#FFE400\'>We do not support Compromised accounts.</font> It is the responsibility of the player to protect the security of their account by using a strong password and never sharing their login information with anyone.<br><br>";
      _loc2_ += "While this is our official policy, we will review your case to see if there is any help we can provide. In most cases the account will not be recoverable due to the inability to prove ownership. Lost cars, money, and parts are not recoverable in almost every case.<br><br>";
      _menuArray[classes.data.SupportCenterData.FORGOT_PASSWORD].displayText = "Enter your username and your password will be emailed to you.";
      _menuArray[classes.data.SupportCenterData.FORGOT_USERNAME].displayText = "We are sorry. We cannot provide support for this problem. There is no way to find your account without the name.";
      _menuArray[classes.data.SupportCenterData.LOST_EMAIL].displayText = "If you have lost access to your email and cannot remember your password there is not a lot we can do to help.  If you are a member or a points customer we may be able to use your billing information to prove account ownership. In most other cases this claim cannot be supported.";
      _menuArray[classes.data.SupportCenterData.ACCOUNT_TAKE_OVER].displayText = "This is a compromised account. Once an account\'s security has been compromised it will not be supported. The policy in the terms of service states that we will not recover compromised acounts. There is no way to prove rightful ownership.";
      _menuArray[classes.data.SupportCenterData.WONT_GIVE_ACCOUNT_BACK].displayText = "Letting another user on your account is strictly prohibited by the terms of service.  You must never share your login information with anyone or allow anyone to access your account by any other means.<br><br>";
      _menuArray[classes.data.SupportCenterData.WONT_GIVE_ACCOUNT_BACK].displayText += _loc2_;
      _menuArray[classes.data.SupportCenterData.SOMEONE_GUESSED_LOGIN].displayText = "If someone guessed your login information you may need to create a much stronger password. A good password is something that will be very hard for others to guess. Never use your username or other available information about yourself as your password. That can be easily guessed.<br>";
      _menuArray[classes.data.SupportCenterData.SOMEONE_GUESSED_LOGIN].displayText += _loc2_;
      _menuArray[classes.data.SupportCenterData.HACKED_VERSION].displayText = _loc2_;
      _menuArray[classes.data.SupportCenterData.HACKED_VERSION].displayText += "Please report the username and the address of the website that is being used to collect login information. The user will be investigated and we will take action to have the website taken down.";
      _menuArray[classes.data.SupportCenterData.TRICKED].displayText = _loc2_;
      _menuArray[classes.data.SupportCenterData.PETITION_ASSETS].displayText = "Assets, items, or currency in the game removed by an Administrator will be justified by evidence of exploitive abuse within the game. For security reasons, we are unable to provide our methods of investigating accounts in question. The items or funds removed will not be returned and the account may be temporarily suspended or permanently closed.";
      var _loc3_ = "This action is considered a deal between players. We highly discourage players from making deals as they can often result in one player losing something valuable.<br>";
      _loc3_ += "A deal between players is not a function that is part of the game programming and is not supported.  We do however allow you to make a claim and report the user that violated your deal. This report will help create a history of offenses for the person you name. This history can be used to take action on this person if necessary. In either case your loss cannot be recovered.";
      _loc3_ += " Please provide as much evidence as possible to help support your claim.";
      _menuArray[classes.data.SupportCenterData.GAVE_MONEY_TO_TEAM_LEADER].displayText = _loc3_;
      _menuArray[classes.data.SupportCenterData.BORROWED_CAR].displayText = _loc3_;
      _menuArray[classes.data.SupportCenterData.MADE_DEAL_NO_DELIVERY].displayText = _loc3_;
      _menuArray[classes.data.SupportCenterData.ACTIVATION_CODE_NO_MEMBERSHIP].displayText = "Please enter your purchase confirmation number below to open a support claim for this problem.";
      _menuArray[classes.data.SupportCenterData.ACTIVATION_CODE_NOT_ACCEPTED].displayText = "Be aware that your purchase transaction also contains a purchase order number. This is not the activation code. The activation code is comprised of numbers and letters and will appear in large green text near the bottom of your receipt page.";
      _menuArray[classes.data.SupportCenterData.ACTIVATION_CODE_NOT_ACCEPTED].displayText += "<br><br>If you are sure you are using the correct code and it continues to fail then continue.";
      _menuArray[classes.data.SupportCenterData.CA_RELIGION].displayText = "Racial slurs, religious slander or sexual harassment will not be tolerated in game or on the forums. <br><br>";
      _menuArray[classes.data.SupportCenterData.CA_RELIGION].displayText += "Players found using racial/ethnic slurs, religious slander or sexual harassment will be given a 2 hour chat ban for the first offense. Additional offenses will incur increased penalties, up to and including account closure.<br><br>";
      _menuArray[classes.data.SupportCenterData.CA_RELIGION].displayText += "Please enter the name of the player you are reporting. In the description box, please include the offensive chat witnessed. ";
      _menuArray[classes.data.SupportCenterData.CA_DEFAME_MOD].displayText = "Creating accounts to harass or impersonate a member of the Nitto 1320 Legends staff will not be tolerated. This include names that defame or insult any staff member, and/or contain sexual, racial or otherwise inappropriate content as determined by Administrators. Accounts created to impersonate staff members to harass or scam other players will not be tolerated. <br><br>";
      _menuArray[classes.data.SupportCenterData.CA_DEFAME_MOD].displayText += "Players found to have created accounts with the intent to harass or insult a staff member, impersonate a staff member, or scam and harass other players will be given a 1 hour suspension for the first offense on their “main” account. The inappropriately named account will be permanently closed . Additional offenses will incur increased penalties, up to and including account closure of the “main” account.<br><br>";
      _menuArray[classes.data.SupportCenterData.CA_DRUG].displayText = "We prohibit the use of illegal drug references in the game and forums at all times.<br><br>";
      _menuArray[classes.data.SupportCenterData.CA_DRUG].displayText += "Players found referencing any illegal drug use in chat or as a user name will be given a temporary 1 hour chat ban, or longer if other violations were previously incurred.<br><br>";
      _menuArray[classes.data.SupportCenterData.CA_DRUG].displayText += "You are reporting the following player for referencing the use of illegal drugs. Please enter the name of the player you wish to report.<br><br>";
      _menuArray[classes.data.SupportCenterData.CA_BAD_LINKS].displayText = "Advertising websites that contain information or instructions for cheats, hacks, scams, or account information phishing will not be tolerated. <br><br>";
      _menuArray[classes.data.SupportCenterData.CA_BAD_LINKS].displayText += "Accounts posting such links or information will be permanently closed. <br><br>";
      _menuArray[classes.data.SupportCenterData.CA_BAD_LINKS].displayText += "Please enter the name of the account you are reporting, and include any other helpful information in the description box, such as chat containing the link and/or advertisement. <br><br>";
      _menuArray[classes.data.SupportCenterData.CA_RACIAL].displayText = "Racial harassment or use of any racial language deemed offensive and used directly or indirectly towards another player is not premitted at any time.<br><br>";
      _menuArray[classes.data.SupportCenterData.CA_RACIAL].displayText += "Players found using racial language or racially harasssing another player will be given a temporary 24 hour login ban, or longer if other violations were previously incurred.<br><br>";
      _menuArray[classes.data.SupportCenterData.CA_RACIAL].displayText += "You are reporting the following user for use of racial language.<br>Please enter the name of the player you wish to report.<br><br>";
      _menuArray[classes.data.SupportCenterData.CA_SEXUAL].displayText = "Use of sexual language is not permitted in the game or forums, and will result in a Warning and chat ban on the first offense.<br><br>";
      _menuArray[classes.data.SupportCenterData.CA_SEXUAL].displayText += "Players found using sexual language or sexually harassing another player will be given a temporary 1 hour chat ban, or longer if other violations were previously incurred.<br><br>";
      _menuArray[classes.data.SupportCenterData.CA_SEXUAL].displayText += "You are reporting the following player for use of sexual language or harassment. Please enter the name of the player you wish to report.<br><br>";
      _menuArray[classes.data.SupportCenterData.CA_PROFANITY].displayText = "Use of inappropriate language will not be tolerated in game or on the forums. This includes: references to illegal drugs, pornographic or overtly sexual references and links, swearing, or anything else deemed inappropriate by the administrators. <br><br>";
      _menuArray[classes.data.SupportCenterData.CA_PROFANITY].displayText += "Players found using inappropriate language in game will receive a verbal warning and a 1 hour chat ban for the first offense. Additional offenses will incur increased penalties, up to and including account closure. Inappropriate language on the forums will incur a warning for the first offense, additional offenses will incur increased penalties. <br><br>";
      _menuArray[classes.data.SupportCenterData.CA_PROFANITY].displayText += "Please enter the name of the player you are reporting. In the description box, please include the offensive chat witnessed. ";
      _menuArray[classes.data.SupportCenterData.CA_THREAT].displayText = "Threatening players with physical harm, stalking or harassment, death threats or the spreading of real life information to the public will not be tolerated in game or on the forums.<br><br>";
      _menuArray[classes.data.SupportCenterData.CA_THREAT].displayText += "Players found to have threatened death or any other real life harm will be given a 24 hour suspension for the first offense.  Additional offenses will incur increased penalties, up to and including account closure, and involvement of law enforcement if deemed necessary by Administrators. <br><br>";
      _menuArray[classes.data.SupportCenterData.CA_THREAT].displayText += "Please enter the name of the player you are reporting. In the description box, please include the offensive chat witnessed. <br><br>";
      _menuArray[classes.data.SupportCenterData.CA_SPAMMING].displayText = "Spamming or \"flooding\" is not allowed in the game or on the forums at any time. Players found doing this will receive a chat ban on the first offense by game staff.<br><br>";
      _menuArray[classes.data.SupportCenterData.CA_SPAMMING].displayText += "Players found spamming will be given a temporary 1 hour chat ban, or longer if other violations were previously incurred.<br><br>";
      _menuArray[classes.data.SupportCenterData.CA_SPAMMING].displayText += "You are reporting the following player for spamming. Please enter the name of the player you wish to report.<br><br>";
      _menuArray[classes.data.SupportCenterData.GLITCH_ACCOUNT_SECURITY].displayText = "Suspected accounts found abusing an account security glitch will be permanently closed pending Admin review.<br><br>";
      _menuArray[classes.data.SupportCenterData.GLITCH_ACCOUNT_SECURITY].displayText += "You are reporting an account security related glitch abuse.<br>Please enter the name of the player you wish to report.";
      _menuArray[classes.data.SupportCenterData.GLITCH_MONEY].displayText = "Any account found abusing any glitch or bug in the game to gain extra points, or cash for their or others own gain will be closed. The account will be closed permanently pending Admin review.<br><br>";
      _menuArray[classes.data.SupportCenterData.GLITCH_MONEY].displayText += "Please enter the name of the player you are reporting. In the description box, please include the information about the glitch or exploit.<br><br>";
      _menuArray[classes.data.SupportCenterData.GLITCH_RACING].displayText = "Any account found abusing exploits to win in any races, including tournaments, will be permanently closed pending Admin review.<br><br>";
      _menuArray[classes.data.SupportCenterData.GLITCH_RACING].displayText += "Please enter the name of the player you are reporting, and include any helpful information in the description box.<br><br>";
      _menuArray[classes.data.SupportCenterData.SCAM_IMPERSONATION].displayText = "Impersonating a member of the staff is not permitted at any time in the game or on the forums. The staff team consists of members on the Admin, Moderator, Guide, and Journalist team. Creation of a username with the intent to impersonate a staff member and providing false information or mislead players will result in immediate action and removal.<br><br>";
      _menuArray[classes.data.SupportCenterData.SCAM_IMPERSONATION].displayText += "We understand that players have certain names that they enjoy using when playing an online game. However, we ask that all players pick a unique username that will easily help distinguish them from staff members.";
      _menuArray[classes.data.SupportCenterData.SCAM_STEALING].displayText = "All transfers of money or cars done outside of the designed UCL method are at risk and not eligible for restoration.  Administrators will however investigate and close account where transactions were made with malicious intent.  Players found scamming money or cars from other players will face penalties up to termination of their account(s).<br><br>";
      _menuArray[classes.data.SupportCenterData.SCAM_STEALING].displayText += "Please enter the name of the player you are reporting, and include any helpful information in the description box.";
      _menuArray[classes.data.SupportCenterData.SCAM_LINKS_TO_HACKED].displayText = "Please report the username and the address of the website that is hosting the illegal version of the game.  The user will be investigated and we will take action to have the website taken down.<br><br>";
      _menuArray[classes.data.SupportCenterData.SCAM_LINKS_TO_PHISHING].displayText = "Please report the username and the address of the phishing website.  The user will be investigated and we will take action to have the website taken down.<br><br>";
   }
}
