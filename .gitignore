# ── Decom: only keep car/ and parts/ ──────────────────────────────────────────
# Exclude everything in decom by default, then re-include car/ and parts/
decom/*
!decom/car/
!decom/parts/

# ── Python runtime ─────────────────────────────────────────────────────────────
builder/venv/
**/__pycache__/
*.pyc

# ── Builder runtime output ──────────────────────────────────────────────────────
builder/saved/

# ── Decompiled scripts (not needed by collaborators) ───────────────────────────
scripts/

# ── OS ─────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
